# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Workaround: AppAmbitPushNotifications 0.3.0 incorrectly uses `import AppAmbitSdk` 
  # while the AppAmbitSdk pod defines its module name as `AppAmbit`.
  installer.pod_targets.each do |pod|
    if pod.name == 'AppAmbitPushNotifications'
      pod_dir = pod.support_files_dir.parent.parent + "AppAmbitPushNotifications"
      
      # Correct the imports and append the missing `updateConsumer` bridge.
      swift_files = Dir.glob(File.join(pod_dir, '**', '*.swift'))
      swift_files.each do |file_path|
        File.chmod(0644, file_path)
        content = File.read(file_path)
        
        # 1. Correct module import
        content.gsub!(/import AppAmbitSdk/, 'import AppAmbit')
        
        # 2. If this is PushNotifications.swift, append the bridge extension
        if File.basename(file_path) == 'PushNotifications.swift' && !content.include?('extension AppAmbit')
          content << "\n\n// Bridge extension to resolve SDK incompatibility\nextension AppAmbit {\n    @objc(updateConsumer:pushEnabled:completion:)\n    public static func updateConsumer(deviceToken: String?, pushEnabled: Bool, completion: (@Sendable (Bool) -> Void)? = nil) {\n        ConsumerService.shared.updateConsumer(deviceToken: deviceToken, pushEnabled: pushEnabled, completion: completion)\n    }\n}\n"
        end
        
        File.write(file_path, content)
      end
    end
  end
end
